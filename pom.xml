<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.example</groupId>
    <artifactId>Wettkampfverwaltung</artifactId>
    <version>1.8</version>
    <name>Wettkampfverwaltung</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <junit.version>5.12.1</junit.version>
        <javafx.version>21.0.6</javafx.version>
        <!-- App-Metadaten für jpackage -->
        <app.name>Wettkampfverwaltung</app.name>
        <app.version>1.8.0</app.version>
        <app.vendor>DeinName</app.vendor>
        <main.class>org.example.wettkampfverwaltung.Launcher</main.class>
    </properties>

    <dependencies>

        <!-- JavaFX: nur controls + fxml -->
        <!-- javafx-web entfernt (WebView nicht benötigt -> spart am meisten Platz) -->
        <!-- javafx-media entfernt: dein SoundPlayer nutzt javax.sound.sampled (java.desktop),
             das ist reines JDK-Audio, hat NICHTS mit javafx-media zu tun.
             javafx-media würdest du nur für javafx.scene.media.MediaPlayer/AudioClip brauchen. -->

        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!--
            WICHTIG: Plattform-Classifier NICHT mehr alle gleichzeitig einbinden.
            jlink/jpackage läuft pro Maschine und braucht nur die native Variante
            der aktuellen Build-Plattform. Maven löst das automatisch über das
            os-maven-plugin (siehe build/extensions unten) -> die richtige
            Variante wird je nach Betriebssystem automatisch gewählt.
        -->

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.4.1</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>${main.class}</mainClass>
                            <addClasspath>true</addClasspath>
                            <classpathPrefix>lib/</classpathPrefix>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>copy-dependencies</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/lib</outputDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <executions>
                    <!--
                        WICHTIG: mvn javafx:run UND mvn javafx:jlink rufen BEIDE
                        die Execution mit der id "default-cli" auf - es gibt nur
                        diese eine. Eine zweite Execution wird von den CLI-Goals
                        nicht automatisch getriggert, deshalb alles hier drin.
                    -->
                    <execution>
                        <id>default-cli</id>
                        <configuration>
                            <mainClass>${main.class}</mainClass>
                            <launcher>app</launcher>
                            <jlinkImageName>app</jlinkImageName>
                            <jlinkZipName>app</jlinkZipName>
                            <noManPages>true</noManPages>
                            <stripDebug>true</stripDebug>
                            <noHeaderFiles>true</noHeaderFiles>
                            <!--
                                Nur die JDK-Module einbinden, die wirklich gebraucht werden.
                                Ermittelt via jdeps; java.desktop für javax.sound.sampled
                                (SoundPlayer), java.scripting kam von jdeps mit dazu.
                            -->
                            <jlinkOptions>
                                <option>--strip-native-commands</option>
                                <option>--no-header-files</option>
                                <option>--no-man-pages</option>
                                <option>--compress=2</option>
                                <option>--add-modules</option>
                                <option>java.base,java.desktop,java.scripting,javafx.controls,javafx.fxml,javafx.graphics</option>
                            </jlinkOptions>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>